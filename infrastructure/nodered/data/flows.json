    {
        "id": "6351e0f8774bc83f",
        "type": "function",
        "z": "468558a4a378aaae",
        "name": "Parser",
        "func": "// 1. Determine Action\nconst eventType = msg.payload.eventType;\nlet command = \"\";\n\nif (eventType === \"NodeCreated\" || eventType === \"NodeUpdated\") {\n    // Logic for START\n    const nodeType = msg.payload.payload.nodeType.toUpperCase(); // \"PRODUCER\" or \"CONSUMER\"\n    command = 'START_'+nodeType;\n} else if (eventType === \"NodeDeleted\") {\n    // Logic for STOP\n    command = \"STOP\";\n} else {\n    console.log('Unknown event type '+eventType)\n    return null;\n}\n\n// 2. Parse the Node ID (\"n_2\" -> \"2\")\nconst nodeIdRaw = msg.payload.payload.nodeId; // \"n_2\"\nconst nodeIdNum = nodeIdRaw.split('_')[1];    // \"2\"\n\n// 3. Set the MQTT Topic\n// Pattern: grid/node/node-{ID}/config\nmsg.topic = 'grid/node/node-'+nodeIdNum+'/config';\n\n// 4. Set the final payload\nmsg.payload = command;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
