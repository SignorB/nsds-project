    {
        "id": "f1c102abbdb7687c",
        "type": "function",
        "z": "468558a4a378aaae",
        "name": "Parser",
        "func": "const eventType = msg.payload.eventType;\n\nif (eventType !== \"MeasurementReported\"){\n    console.log('Not a successful measurement: ' + eventType);\n    return null;\n}\n\nconst nodeType = msg.payload.payload.nodeType.toUpperCase();\n\nif (nodeType === \"PRODUCER\" || nodeType === \"CONSUMER\") {\n    \n    if (msg.payload.payload.accumulatorNodeId) {\n        const accNodeIdRaw = msg.payload.payload.accumulatorNodeId; // \"n_2\"\n        const accNodeIdNum = accNodeIdRaw.split('_')[1];\n        \n        msg.topic = 'grid/node/node-' + accNodeIdNum + '/acc';\n\n        const value = msg.payload.payload.value;\n        const sign = value >= 0 ? 'P' : 'N';\n        msg.payload = 'VALUE_' + sign + Math.abs(value);\n\n        return msg;\n    } else {\n        console.log('accumulatorNodeId is missing or null');\n        return null; \n    }\n    \n} else {\n    console.log('Unknown node type: ' + nodeType);\n    return null;\n}",
