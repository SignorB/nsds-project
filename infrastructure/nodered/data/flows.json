    {
        "id": "72774fa5757eb963",
        "type": "function",
        "z": "1635ce2323ac27b4",
        "name": "Parser",
        "func": "// 1. Extract Node ID from the MQTT Topic\n// Input Topic: \"grid/node/node-2/measurements\"\nconst topicParts = msg.topic.split('/');\nconst nodeSegment = topicParts[2]; // \"node-2\"\nconst rawId = nodeSegment.split('-')[1]; // \"2\"\n\n// Construct the target ID: \"n_2\"\nconst targetNodeId = 'n_'+rawId;\n\n// 2. Parse the Value\nconst moteValue = parseInt(msg.payload.toString());\n\n// 3. Construct the Kafka Message\nconst kafkaMessage = {\n    \"nodeId\": targetNodeId,\n    \"value\": moteValue,\n    \"timestamp\": Date.now().toString()\n};\n\n// 4. Send to Kafka\nmsg.payload = kafkaMessage;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
